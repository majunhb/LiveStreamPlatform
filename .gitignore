# ============================================================
# Git 忽略配置文件
# 直播平台项目 - .gitignore
# ============================================================

# ----------------------------------------------------------
# Java / Maven
# ----------------------------------------------------------
# 编译产物
*.class
*.jar
*.war
*.ear
*.nar

# Maven
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar

# ----------------------------------------------------------
# Node.js / npm
# ----------------------------------------------------------
# 依赖
node_modules/
.npm

# 构建产物
dist/
dist-ssr/
*.local

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 环境变量
.env
.env.local
.env.*.local

# IDE
.npmrc

# ----------------------------------------------------------
# IDE / Editors
# ----------------------------------------------------------
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extenstions.json

# Eclipse
.project
.classpath
.settings/
.factorypath
.metadata/
bin/

# Spring Tool Suite
*.springBeans
*.springBusiness
*.springData/

# NetBeans
nbproject/private/
build/
nbbuild/
dist/
nbdist/
.nb-gradle/

# ----------------------------------------------------------
# Docker
# ----------------------------------------------------------
# Docker volume data (生产环境数据不提交)
docker/data/
docker/volumes/
**/data/
**/logs/
**/*.log

# Docker 构建缓存
.docker/

# 容器内部文件
objs/
dvr/

# ----------------------------------------------------------
# Operating Systems
# ----------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Icon
Icon?
Icon\r
Icon\r\r

# Thumbnails
._*

# Files that might appear on external disk
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# ----------------------------------------------------------
# Logs & Temporary Files
# ----------------------------------------------------------
*.log
logs/
*.log.*

# 临时文件
*.tmp
*.temp
*.swp
*.swo
*~
.cache/

# ----------------------------------------------------------
# Database
# ----------------------------------------------------------
*.sql.bak
*.sqlite
*.sqlite3
*.db.bak

# ----------------------------------------------------------
# Security
# ----------------------------------------------------------
# 密钥和证书
*.pem
*.key
*.keystore
*.jks
*.truststore
*.p12
*.p8

# Secrets (不要提交真实密钥)
application-secrets.yml
application-secret.properties
secrets/

# ----------------------------------------------------------
# Build Scripts
# ----------------------------------------------------------
*.sh
#!/bin/bash

# 除非是基础设施脚本，否则不跟踪
# infra/**/*.sh 会被跟踪（基础设施配置）

# ----------------------------------------------------------
# Testing
# ----------------------------------------------------------
test-output/
surefire-reports/
failsafe-reports/
jacoco.exec
*.exec

coverage/
.nyc_output/

# ----------------------------------------------------------
# Documentation Build
# ----------------------------------------------------------
docs/_build/
docs/.doctrees/

# ----------------------------------------------------------
# MinIO / Object Storage
# ----------------------------------------------------------
.minio.sys/

# ----------------------------------------------------------
# SRS Streaming
# ----------------------------------------------------------
objs/srs.log*
objs/srs.pid
objs/nginx/

# ----------------------------------------------------------
# Misc
# ----------------------------------------------------------
*.bak
*.orig
*.rej
*.orig.*
*.patch
*.diff

# Thread dump file for JVM
*.tdump

# Heap dump file
*.hprof
*.hprof.*

# Renders
*.rendered

# Package Files
*.zip
*.tar.gz
*.rar
*.tar
*.7z

# Application specific
*.srt
*.vtt
*.csv
