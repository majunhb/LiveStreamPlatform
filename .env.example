# ============================================================
# LiveStreamPlatform 环境变量配置示例
# 复制此文件为 .env 并填写实际值
# ============================================================

# ---------- 数据库 ----------
MYSQL_ROOT_PASSWORD=your_secure_db_password
MYSQL_USER=root

# ---------- Redis ----------
REDIS_PASSWORD=

# ---------- MongoDB ----------
MONGO_PASSWORD=

# ---------- MinIO ----------
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key

# ---------- JWT ----------
# 生成方式: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_at_least_256_bits_long

# ---------- Nacos ----------
NACOS_PASSWORD=nacos
NACOS_SERVER_ADDR=127.0.0.1:8848

# ---------- CORS ----------
# 多个域名用逗号分隔
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://admin.yourdomain.com

# ---------- 应用服务端口（可选） ----------
# DB_HOST=127.0.0.1
# DB_PORT=3306
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# KAFKA_SERVERS=127.0.0.1:9092
# MONGO_HOST=127.0.0.1
# MONGO_PORT=27017
